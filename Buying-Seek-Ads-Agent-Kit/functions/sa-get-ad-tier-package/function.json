{
  "name": "sa-get-ad-tier-package",
  "description": "Recommends the best Seek branded ad budget package from the caller's identity and how many ads they need. Pass advertiserId (from IDV) and adCount (2–10); maps to Occasional, Regular, or Frequent and returns budget, discounts, and summary text.",
  "handler": "handler.handler",
  "runtime": "nodejs_22.x",
  "input": {
    "type": "object",
    "properties": {
      "adCount": {
        "type": "number",
        "title": "Number of job ads",
        "description": "Required. Number of job ads (2–10). Auto-selects best tier: 2–3 occasional, 4–6 regular, 6–10 frequent."
      },
      "advertiserId": {
        "type": "string",
        "title": "Advertiser ID",
        "description": "Required. advertiserId from sa_idv_advertiser (caller identity)."
      },
      "seekId": {
        "type": "string",
        "title": "Seek ID",
        "description": "Optional fallback if advertiserId is unavailable."
      },
      "tier": {
        "type": "string",
        "title": "Hiring tier",
        "description": "Optional override. Usually omit — adCount selects the best package."
      },
      "listTiers": {
        "type": "boolean",
        "title": "List all tiers",
        "description": "Optional. If true, lists tiers only (do not use for package recommendation)."
      },
      "storePath": { "type": "string" }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean", "title": "Success" },
      "tier": { "type": "string", "title": "Recommended tier" },
      "tierLabel": { "type": "string", "title": "Tier label" },
      "adRangeDisplay": { "type": "string", "title": "Ad range" },
      "adCount": { "type": "number", "title": "Number of job ads" },
      "cardPriceDisplay": { "type": "string", "title": "Card price" },
      "recommendedBudgetAud": { "type": "number", "title": "Recommended budget (AUD)" },
      "recommendedBudgetDisplay": { "type": "string", "title": "Recommended budget" },
      "summaryText": { "type": "string", "title": "Package recommendation" },
      "advertiserId": { "type": "string", "title": "Advertiser ID" },
      "companyName": { "type": "string", "title": "Company name" },
      "currency": { "type": "string", "title": "Currency" },
      "discounts": { "type": "array", "title": "Discounts" },
      "brandedAdBudget": { "type": "object", "title": "Branded ad budget" },
      "eligibleAdTypes": { "type": "array", "title": "Eligible ad types" },
      "howItWorks": { "type": "array", "title": "How it works" },
      "termsNote": { "type": "string", "title": "Terms note" },
      "openingLine": { "type": "string", "title": "Opening line" },
      "seekId": { "type": "string", "title": "Seek ID" },
      "availableTiers": { "type": "array", "title": "Available tiers" },
      "message": { "type": "string", "title": "Message" },
      "details": { "type": "object", "title": "Details" },
      "error": { "type": "string", "title": "Error" },
      "code": { "type": "string", "title": "Error code" }
    }
  }
}
